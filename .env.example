# Copy this file to .env.
# .env is ignored by git.

AURAOS_LLM_PROVIDER=ollama
AURAOS_OLLAMA_MODEL=gemma3:4b
AURAOS_OLLAMA_BASE_URL=http://127.0.0.1:11434

# Optional Ollama / local limits:
# AURAOS_LLM_MAX_INPUT_CHARS=6000
# AURAOS_LLM_MAX_OUTPUT_TOKENS=450

# Optional OpenAI fallback, only if you switch provider:
# AURAOS_LLM_PROVIDER=openai
# OPENAI_API_KEY=replace_with_your_api_key
# AURAOS_OPENAI_MODEL=gpt-4.1-mini
